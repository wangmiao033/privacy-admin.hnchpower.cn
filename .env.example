# 复制为 .env.local 后填写（勿提交 .env.local）

# Supabase 项目（与前台可共用同一项目）
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# 仅服务端（勿暴露到浏览器）：
# - 仪表盘/访问统计/访问日志：page_visit_logs 与 *_svc 统计 RPC（推荐必填）
# - 用户管理「最近登录」、POST /api/ingest/policy-publish-log
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# 允许跨域调用发布记录 API 的前台来源（逗号分隔）；不配则默认 privacy 正式域 + localhost:3000
# POLICY_PUBLISH_LOG_ALLOWED_ORIGINS=https://privacy.hnchpower.cn,http://localhost:3000

# —— 每日邮件报告（/api/cron/daily-report）——
DAILY_REPORT_ENABLED=true
# 多个收件人用英文逗号分隔，如 a@qq.com,b@qq.com
DAILY_REPORT_TO=wangmiao033@gmail.com
DAILY_REPORT_SUBJECT_PREFIX=[admin.hnchpower.cn]
# 实际调度以 vercel.json 为准（默认 0 1 * * * = 北京时间约 9:00）；以下为文档/外部 cron 参考
# DAILY_REPORT_CRON=0 9 * * *
REPORT_TIMEZONE=Asia/Shanghai
CRON_SECRET=请生成随机串并在 Vercel Cron 同项目环境变量中配置

# 数据保留（日报任务内每日最多执行一次 DELETE）
LOG_RETENTION_DAYS=60
JOB_LOG_RETENTION_DAYS=90

# SMTP（发信）
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# —— 无 Vercel Cron 时：用外部定时器请求 ——
# curl -s -H "Authorization: Bearer $CRON_SECRET" "https://admin.hnchpower.cn/api/cron/daily-report"
# 测试（跳过去重/清理，仍发真实邮件）：追加 ?test=1
