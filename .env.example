# 复制为 .env.local 后填写（勿提交 .env.local）

# Supabase 项目（与前台可共用同一项目）
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# 仅服务端（勿暴露到浏览器）：
# - 用户管理「最近登录」、POST /api/ingest/policy-publish-log 写入发布记录
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# 允许跨域调用发布记录 API 的前台来源（逗号分隔）；不配则默认 privacy 正式域 + localhost:3000
# POLICY_PUBLISH_LOG_ALLOWED_ORIGINS=https://privacy.hnchpower.cn,http://localhost:3000
